{
  "name": "claude-bioflow devcontainer",
  "build": {
    "context": "..",
    "dockerfile": "../image/Dockerfile"
  },
  "remoteUser": "node",
  "workspaceFolder": "/workspace",
  "mounts": [
    "source=${localWorkspaceFolder}/hub/workspaces/devuser/.claude/skills,target=/home/node/.claude/skills,type=bind",
    "source=${localWorkspaceFolder}/hub/workspaces/devuser/.claude/agents,target=/home/node/.claude/agents,type=bind",
    "source=${localWorkspaceFolder}/hub/workspaces/devuser/.claude/chats,target=/workspace/.claude/chats,type=bind"
  ],
  "runArgs": [
    "--network=host"
  ],
  "containerEnv": {
    "ID_HASH": "devcontainer0",
    "NATS_SERVERS": "nats://localhost:4223",
    "WORKSPACE_ROOT": "/workspace",
    "DEFAULT_PROJECT": "/workspace",
    "HOME": "/home/node"
  },
  "postCreateCommand": "node --version && claude --version"
}
